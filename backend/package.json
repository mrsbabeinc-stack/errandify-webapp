{
  "name": "errandify-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=${NODE_EXTRA_CA_CERTS:-/etc/ssl/cert.pem} tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "NODE_EXTRA_CA_CERTS=${NODE_EXTRA_CA_CERTS:-/etc/ssl/cert.pem} node ../backend/dist/index.js",
    "lint": "eslint src --ext ts",
    "seed:blog": "tsx src/db/seed-blog-production.ts",
    "seed:errands": "tsx src/scripts/seed-sample-errands.ts"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "isomorphic-dompurify": "^2.30.0",
    "jose": "^6.2.4",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "socket.io": "^4.8.3",
    "stripe": "^14.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
