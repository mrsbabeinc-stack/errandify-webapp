{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "noEmitOnError": false,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "allowJs": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/scripts/**/*.ts",
    "src/services/stripe.ts",
    "src/services/ossService.ts",
    "src/services/S3StorageService.ts",
    "src/db/migrations/**/*.ts"
  ]
}
