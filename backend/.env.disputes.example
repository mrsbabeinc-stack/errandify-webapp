# Dispute Resolution System Configuration
# Copy to .env and fill in your actual values

# ============================================================================
# AWS S3 Configuration (for evidence file storage)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=errandify-disputes

# ============================================================================
# File Storage Settings
# ============================================================================
# Maximum file size for evidence uploads (bytes)
MAX_EVIDENCE_FILE_SIZE=52428800  # 50MB

# Auto-compression targets
MAX_PHOTO_SIZE=5242880           # 5MB
MAX_VIDEO_SIZE=20971520          # 20MB
PHOTO_COMPRESSION_QUALITY=80     # JPEG quality (0-100)

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=disputes@errandify.ai

# ============================================================================
# SMS Configuration (for urgent reminders at T+36h)
# ============================================================================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ============================================================================
# AI Analysis Configuration (Qwen for evidence analysis)
# ============================================================================
QWEN_API_KEY=your_qwen_api_key
QWEN_MODEL=qwen-vision-plus
QWEN_TIMEOUT=30000  # milliseconds

# ============================================================================
# Dispute Configuration
# ============================================================================
# 3-Day Resolution Timeline (DO NOT CHANGE)
DISPUTE_RESPONSE_DEADLINE_HOURS=24
DISPUTE_AUTO_RESOLVE_HOURS=48
DISPUTE_APPEAL_WINDOW_HOURS=12
DISPUTE_EXTENSION_HOURS=12

# Reminders
DISPUTE_REMINDER_1_HOURS=24  # First reminder (email)
DISPUTE_REMINDER_2_HOURS=36  # Second reminder (SMS + Email + Push)

# Auto-resolution strategy
# AUTO_RESOLVE_STRATEGY can be: EVIDENCE_COUNT, CONFIDENCE_SCORE, HYBRID
AUTO_RESOLVE_STRATEGY=EVIDENCE_COUNT

# ============================================================================
# Payment Integration
# ============================================================================
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Hold/Release Configuration
PAYMENT_HOLD_ON_DISPUTE=true
PAYMENT_HOLD_RELEASE_DELAY_MINUTES=5  # After resolution

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/errandify_disputes

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json

# ============================================================================
# Background Jobs
# ============================================================================
# Reminder job frequency (minutes)
REMINDER_JOB_INTERVAL=30

# Auto-resolve job frequency (minutes)
AUTO_RESOLVE_JOB_INTERVAL=30

# Appeal resolution job frequency (minutes)
APPEAL_JOB_INTERVAL=60

# Payment settlement job frequency (minutes)
PAYMENT_SETTLEMENT_JOB_INTERVAL=5

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_ANALYSIS=true
ENABLE_AUTO_COMPRESSION=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_AUTO_RESOLUTION=true

# ============================================================================
# Development/Testing
# ============================================================================
NODE_ENV=production  # development, production
DEBUG=false
