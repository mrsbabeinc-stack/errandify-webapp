# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For Local Development (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=errandify_local

# For Alibaba Cloud RDS Production (Uncomment and set when deploying)
# NODE_ENV=production
# DB_HOST=rm-xxxxx.mysql.rds.aliyuncs.com
# DB_PORT=3306
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_NAME=errandify
# DB_READ_REPLICAS=rm-xxxxx-read.mysql.rds.aliyuncs.com

# JWT Secret (for authentication tokens)
JWT_SECRET=your-secret-key-change-in-production

# Alibaba Qwen API (for AI features like text extraction, TTS)
QWEN_API_KEY=sk-ws-...

# Stripe API Keys (for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# SingPass MyInfo v5 Integration (for user authentication & data)
USE_SINGPASS=true
SINGPASS_CLIENT_ID=STG-xxxxx-LOGIN-Errand-xxxxx
SINGPASS_REDIRECT_URI=https://app-dev.errandify.ai/register-sing-pass
SINGPASS_JWKS_ENDPOINT=https://api-dev.errandify.ai/api/.well-known/jwks.json
SINGPASS_ENVIRONMENT=staging

# NewsAPI (for Singapore news articles)
NEWS_API_KEY=your-news-api-key

# Frontend URL
VITE_API_URL=http://localhost:3000

# ============================================================================
# LOGGING & MONITORING (for production diagnostics)
# ============================================================================
LOG_LEVEL=debug
ENABLE_SLOW_QUERY_LOG=true
SLOW_QUERY_THRESHOLD=1000
