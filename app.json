{
  "name": "Errandify",
  "description": "Singapore's trusted gig economy platform for errands and services",
  "repository": "https://github.com/your-org/errandify",
  "keywords": [
    "gig-economy",
    "errands",
    "singapore",
    "services",
    "marketplace"
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production",
      "required": false
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens",
      "value": "test-secret-key-staging",
      "required": false
    },
    "DATABASE_URL": {
      "description": "PostgreSQL database URL (added by Heroku Postgres addon)",
      "required": false
    },
    "QWEN_API_KEY": {
      "description": "Alibaba Qwen API key for AI features",
      "value": "",
      "required": false
    },
    "MAPBOX_API_KEY": {
      "description": "Mapbox API key for address geocoding",
      "value": "",
      "required": false
    },
    "STRIPE_SECRET_KEY": {
      "description": "Stripe secret key for payments",
      "value": "",
      "required": false
    },
    "USE_SINGPASS": {
      "description": "Enable SingPass authentication",
      "value": "false",
      "required": false
    }
  },
  "addons": [],
  "stack": "heroku-24"
}
