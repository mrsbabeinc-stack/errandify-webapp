# Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost/errandify

# JWT Secret (for authentication)
JWT_SECRET=your-secret-key-change-in-production

# Alibaba Qwen API (REQUIRED for AI features)
# Get your API key from: https://dashscope.console.aliyun.com/
# This is needed for:
# - Category detection from errand titles
# - Parsing natural language dates/times
# - Content filtering (safety check)
# - Title completion suggestions
# - Speech-to-text transcription
# - Hana conversational AI
QWEN_API_KEY=your-alibaba-api-key-here

# Stripe (for payments - optional for testing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# SingPass Integration (optional)
USE_SINGPASS=false
SINGPASS_CLIENT_ID=your-singpass-client-id
SINGPASS_CLIENT_SECRET=your-singpass-client-secret

# Frontend
VITE_API_URL=http://localhost:3000
